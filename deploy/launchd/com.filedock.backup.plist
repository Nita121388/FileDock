<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.filedock.backup</string>

    <key>ProgramArguments</key>
    <array>
      <string>filedock</string>
      <string>push-folder-loop</string>
      <string>--server</string>
      <string>http://127.0.0.1:8787</string>
      <string>--device</string>
      <string>macbook</string>
      <string>--folder</string>
      <string>/Users/you/Documents</string>
      <string>--interval-secs</string>
      <string>900</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <!-- Run every 15 minutes (900 seconds). -->
    <key>StartInterval</key>
    <integer>900</integer>

    <key>StandardOutPath</key>
    <string>/tmp/filedock-backup.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/filedock-backup.err.log</string>
  </dict>
</plist>

