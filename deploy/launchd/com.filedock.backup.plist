<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.filedock.backup</string>

    <key>ProgramArguments</key>
    <array>
      <string>filedock</string>
      <string>agent</string>
      <string>--config</string>
      <string>/Users/you/.config/filedock/agent.toml</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <!-- Keep the agent alive (agent.toml controls interval/heartbeat). -->
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/filedock-backup.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/filedock-backup.err.log</string>
  </dict>
</plist>
